{
  "name": "central-intelligence-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for Central Intelligence — persistent memory for AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agents", "memory", "mcp", "central-intelligence", "langchain", "openai", "llm"],
  "author": "AlekseiMarchenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AlekseiMarchenko/central-intelligence",
    "directory": "packages/node-sdk"
  },
  "homepage": "https://centralintelligence.online",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
